{
    "workbench.colorTheme": "Monokai",
    "workbench.preferredDarkColorTheme": "Default High Contrast",
    "editor.acceptSuggestionOnCommitCharacter": true,
    "editor.inlineSuggest.experimental.showOnSuggestConflict": "always",
    "editor.inlineSuggest.suppressSuggestions": true,
    "editor.suggest.localityBonus": true,
    "editor.suggest.shareSuggestSelections": true,
    "editor.suggest.snippetsPreventQuickSuggestions": true,
    "search.searchView.keywordSuggestions": true,
    "debug.console.acceptSuggestionOnEnter": "on",
    "emmet.showSuggestionsAsSnippets": true,
    "html.suggest.hideEndTagSuggestions": true,
    "javascript.suggest.completeFunctionCalls": true,
    "typescript.suggest.completeFunctionCalls": true,
    "editor.inlineCompletionsAccessibilityVerbose": true,
    "diffEditor.experimental.useTrueInlineView": true,
    "editor.inlineSuggest.edits.showCollapsed": false,
    "notebook.diff.experimental.toggleInline": true,
    "notebook.inlineValues": "auto",
    "emmet.useInlineCompletions": true,
    "debugpy.showPythonInlineValues": true,
    "terminal.integrated.enableImages": false
}